{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/pro",
      "destination": "/pricing",
      "permanent": true
    },
    {
      "source": "/gpm-lpm-calculator",
      "destination": "/lpm-gpm-calculator",
      "permanent": true
    },
    {
      "source": "/go/setup-fb",
      "destination": "/calculator?utm_source=facebook&utm_medium=social&utm_campaign=setup_calculator&utm_content=fb_post",
      "permanent": false
    },
    {
      "source": "/go/setup-ig",
      "destination": "/calculator?utm_source=instagram&utm_medium=social&utm_campaign=setup_calculator&utm_content=ig_story",
      "permanent": false
    },
    {
      "source": "/go/setup-yt",
      "destination": "/calculator?utm_source=youtube&utm_medium=social&utm_campaign=setup_calculator&utm_content=yt_shorts",
      "permanent": false
    },
    {
      "source": "/go/hose-fb",
      "destination": "/hose-pressure-loss-calculator?utm_source=facebook&utm_medium=social&utm_campaign=hose_loss&utm_content=fb_post",
      "permanent": false
    },
    {
      "source": "/go/nozzle-fb",
      "destination": "/nozzle-size-calculator?utm_source=facebook&utm_medium=social&utm_campaign=nozzle_size&utm_content=fb_post",
      "permanent": false
    },
    {
      "source": "/go/psi-bar-yt",
      "destination": "/psi-bar-calculator?utm_source=youtube&utm_medium=social&utm_campaign=psi_bar&utm_content=yt_shorts",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/s/:code",
      "destination": "/api/share-landing?code=:code"
    },
    {
      "source": "/((?!api/|@vite/|@react-refresh|src/|node_modules/|robots\\.txt|sitemap\\.xml|favicon\\.ico|favicon\\.svg|favicon-96x96\\.png|apple-touch-icon\\.png|site\\.webmanifest|assets/).*)",
      "destination": "/"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ]
}
