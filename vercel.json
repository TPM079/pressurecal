{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/pro",
      "destination": "/pricing",
      "permanent": true
    },
    {
      "source": "/gpm-lpm-calculator",
      "destination": "/lpm-gpm-calculator",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/s/:code",
      "destination": "/api/share-landing?code=:code"
    },
    {
      "source": "/((?!api/|@vite/|@react-refresh|src/|node_modules/|robots\\.txt|sitemap\\.xml|favicon\\.ico|favicon\\.svg|favicon-96x96\\.png|apple-touch-icon\\.png|site\\.webmanifest|assets/).*)",
      "destination": "/"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ]
}